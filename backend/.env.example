# Backend Environment Configuration
# Copy this file to .env and update values

# =============================================================================
# Model Configuration - DUAL-TIER SYSTEM (Recommended)
# =============================================================================

# Tier 1 Model: Generic Routing (Material Agent)
# Classes: ORGANIC, RECYCLABLE, NON_RECYCLABLE
TIER1_MODEL_PATH=models/yolov8_tier1.pt

# Tier 2 Model: Specific Material ID (Routing Agent)
# Classes: cardboard, glass, metal, paper, plastic, battery, biological, clothes, shoes, trash, e-waste, medical, green-glass
TIER2_MODEL_PATH=models/yolov8_tier2.pt

# Confidence thresholds for each tier
MODEL_CONF_TIER1=0.35
MODEL_CONF_TIER2=0.35

# =============================================================================
# Model Configuration - LEGACY SINGLE-MODEL (Fallback)
# =============================================================================
# If TIER1_MODEL_PATH and TIER2_MODEL_PATH are not set, falls back to single model

# Path to trained YOLO model
MODEL_PATH=models/yolov8m_waste.pt
# Options: models/yolov8n.pt (nano, fastest), yolov8s.pt (small), 
#          yolov8m.pt (medium, recommended), yolov8l.pt (large)

# Legacy confidence threshold
MODEL_CONF=0.35

# =============================================================================
# Common Model Settings
# =============================================================================

# Device for inference
MODEL_DEVICE=cpu
# Options: 'cuda' (NVIDIA GPU), 'cpu', 'mps' (Apple Silicon)

# Input image size
MODEL_IMGSZ=640
# Options: 320, 416, 512, 640 (recommended), 1280
# Larger = more accurate but slower

# =============================================================================
# Camera Configuration
# =============================================================================

# Camera source
CAMERA_SOURCE=0
# Options: 
#   0 (default webcam)
#   1, 2, 3... (other camera indices)
#   rtsp://192.168.1.100:554/stream (IP camera)
#   /path/to/video.mp4 (video file for testing)

# =============================================================================
# System Configuration
# =============================================================================

# Enable real YOLO inference (1) or use simulator (0)
USE_REAL_INFERENCE=1
# Set to 0 for testing without camera/model

# =============================================================================
# Database Configuration (Optional - For Future Implementation)
# =============================================================================

# DATABASE_URL=postgresql://user:password@localhost:5432/cognirecycle
# Uncomment and configure if using PostgreSQL

# =============================================================================
# Advanced Configuration
# =============================================================================

# Adaptive threshold adjustment
ADAPTIVE_ENABLED=true
ADAPTIVE_MIN_THRESHOLD=0.60
ADAPTIVE_MAX_THRESHOLD=0.95

# Contamination monitoring
CONTAMINATION_WARNING_THRESHOLD=15.0
CONTAMINATION_CRITICAL_THRESHOLD=25.0

# WebSocket configuration
WS_HEARTBEAT_INTERVAL=30

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
